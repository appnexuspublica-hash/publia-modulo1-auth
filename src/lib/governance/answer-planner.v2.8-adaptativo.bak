// src/lib/governance/answer-planner.ts

import type { GovernanceResponseMode } from "@/types/governance";

type BuildGovernanceAnswerPlanParams = {
  responseMode: GovernanceResponseMode;
  question: string;
  hasEvidenceContext: boolean;
  hasMunicipalContext: boolean;
};

function buildModeSpecificInstruction(mode: GovernanceResponseMode) {
  switch (mode) {
    case "objective":
      return "Seja direto. Use poucos parágrafos e bullets apenas quando ajudarem a decisão.";
    case "summary":
      return "Resuma sem perder fundamentos essenciais, riscos e aplicação prática.";
    case "checklist":
      return "Nas seções 4 e 5, privilegie itens verificáveis em formato de checklist.";
    case "technical_opinion":
      return "Adote redação técnica, fundamentada e prudente, sem simular parecer jurídico vinculante.";
    case "risk_analysis":
      return "Destaque riscos, consequências e controles preventivos principalmente nas seções 3 e 5.";
    case "attention_points":
      return "Priorize alertas objetivos, pontos críticos e providências imediatas.";
    case "action_plan":
      return "Na seção 4, organize a aplicação ao Município em passos executáveis e ordenados.";
    case "draft":
      return "Mantenha a estrutura abaixo, mas redija o conteúdo em linguagem aproveitável em minuta administrativa.";
    case "comparison":
      return "Quando houver alternativas, compare-as de forma clara dentro das seções 2, 3 e 4.";
    case "manager_guidance":
      return "Oriente o gestor com foco em decisão, responsabilidade, controles e próximos passos.";
    default:
      return "Responda com clareza técnica, utilidade administrativa e prudência.";
  }
}

export function buildGovernanceAnswerPlan({
  responseMode,
  question,
  hasEvidenceContext,
  hasMunicipalContext,
}: BuildGovernanceAnswerPlanParams) {
  const evidenceInstruction = hasEvidenceContext
    ? "Há um dossiê prévio de evidências oficiais disponível. Use-o como referência prioritária e não crie atos, acórdãos, números, datas ou URLs que não estejam sustentados por esse contexto."
    : "Não invente atos, acórdãos, números, datas ou URLs. Quando faltar evidência suficiente, declare a limitação de forma objetiva.";

  const municipalInstruction = hasMunicipalContext
    ? "Há contexto institucional ou municipal disponível. Use-o somente quando for pertinente à pergunta e diferencie claramente norma geral, orientação de controle e prática local."
    : "Não presuma regra municipal específica sem evidência no contexto.";

  return [
    "PLANEJADOR OBRIGATÓRIO DA RESPOSTA — GOVERNANÇA",
    "",
    `Pergunta atual: ${question}`,
    "",
    "A resposta final deve seguir exatamente esta ordem lógica:",
    "",
    "## 1. Resposta objetiva",
    "Comece pela conclusão principal em 2 a 5 frases. Responda diretamente ao que foi perguntado, sem introdução genérica.",
    "",
    "## 2. Fundamentação",
    "Explique as razões jurídicas, técnicas ou administrativas que sustentam a resposta. Cite no corpo apenas normas e documentos realmente apoiados pelo contexto disponível.",
    "",
    "## 3. Entendimento atual",
    "Apresente o entendimento vigente de órgãos de controle, tribunais, CGU, TCU ou autoridades competentes quando isso for relevante. Diferencie lei, orientação, jurisprudência e boa prática.",
    "",
    "## 4. Aplicação ao Município",
    "Traduza a conclusão para a rotina municipal. Indique como o Município deve aplicar o entendimento, quais áreas devem participar e quais providências práticas são recomendadas.",
    "",
    "## 5. Cuidados",
    "Liste riscos, exceções, documentos necessários, validações e situações que exigem análise jurídica, controle interno ou confirmação em fonte oficial.",
    "",
    "As seções 6 e 7 NÃO devem ser escritas pelo modelo no corpo da resposta:",
    "6. Base legal",
    "7. Fontes",
    "O backend acrescentará essas duas seções automaticamente com as referências estruturadas. Não repita, antecipe ou crie seções chamadas 'Base Legal', 'Fontes', 'Fontes consultadas', 'Referências' ou equivalentes.",
    "",
    "REGRAS DE QUALIDADE:",
    "- Use exatamente os títulos das seções 1 a 5 acima.",
    "- Não omita nenhuma das cinco seções. Quando uma seção não se aplicar, escreva uma frase curta explicando isso.",
    "- Evite repetir a mesma informação em seções diferentes.",
    "- Evite respostas excessivamente longas: priorize síntese, decisão e utilidade administrativa.",
    "- Não use frases promocionais nem encerre oferecendo ajuda adicional; finalize na seção 5.",
    "- Não trate recomendações como obrigação legal quando forem apenas boa prática.",
    "- Não misture fonte institucional municipal com fonte normativa federal sem indicar a diferença.",
    `- ${buildModeSpecificInstruction(responseMode)}`,
    `- ${evidenceInstruction}`,
    `- ${municipalInstruction}`,
  ].join("\n");
}
